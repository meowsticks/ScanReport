{
  "name": "gssi-scan-report",
  "private": true,
  "version": "1.0.16",
  "description": "AK ScanReport — GSSI ground-penetrating radar scan report builder.",
  "author": "Aggarwal Kamikazes Cutting & Coring Ltd",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n vite,electron \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "app:build": "vite build && electron-builder",
    "app:build:win": "vite build && electron-builder --win --publish never",
    "app:build:mac": "vite build && electron-builder --mac",
    "app:build:linux": "vite build && electron-builder --linux",
    "app:publish:win": "vite build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "ca.aggarwalkamikazes.scanreport",
    "productName": "AK ScanReport",
    "publish": [
      {
        "provider": "github",
        "owner": "meowsticks",
        "repo": "ScanReport",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "akscan",
        "name": "AK Scan Report",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/kamikaze-logo.png",
      "artifactName": "AK.ScanReport.Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/kamikaze-logo.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/kamikaze-logo.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.106.1",
    "electron-context-menu": "^3.6.1",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^9.0.10"
  }
}
